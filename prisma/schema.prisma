generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  GESTAO
  COMERCIAL
  MARKETING
  CLIENTE
}

enum QuoteStatus {
  RECEIVED
  IN_ANALYSIS
  ANSWERED
  APPROVED
  REJECTED
}

enum TicketStatus {
  NOVO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  FECHADO
}

enum ShipmentStatus {
  RECEIVED
  PREPARING
  COLLECTED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  ISSUE
}

enum TimelineEventType {
  LEAD_CREATED
  LEAD_UPDATED
  OPPORTUNITY_CREATED
  STAGE_CHANGED
  NOTE_ADDED
  OPPORTUNITY_WON
  OPPORTUNITY_LOST
}

enum OpportunityStage {
  NOVO
  QUALIFICADO
  PROPOSTA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum LeadTimelineEventType {
  CREATED_MANUAL
  IMPORTED_CSV
  UPDATED
  WHATSAPP_CREATED
  WHATSAPP_INTERACTION
  NOTE_ADDED
}

enum LeadImportJobStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum LeadImportRowStatus {
  IMPORTED
  SKIPPED
  FAILED
}

enum MessageSenderType {
  CLIENTE
  INTERNO
  AI
}

enum ContentType {
  NOTICIA
  INFORMACAO
  VLOG
}

enum AuditLogCategory {
  ACCESS
  AUTH
  USER
  CLIENT
  QUOTE
  TICKET
  TRACKING
  SYSTEM
}

enum AuditLogLevel {
  INFO
  WARNING
  ERROR
}

enum AuditLogAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  SESSION_VALIDATED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_STATUS_CHANGED
  CLIENT_CREATED
  CLIENT_UPDATED
  QUOTE_CREATED
  QUOTE_STATUS_CHANGED
  QUOTE_RESPONDED
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  TRACKING_QUERIED
  TRACKING_UPDATED
  CUSTOM
}

model User {
  id                        String              @id @default(uuid())
  name                      String
  email                     String              @unique
  passwordHash              String
  role                      UserRole            @default(CLIENTE)
  isActive                  Boolean             @default(true)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  clientProfile             Client?
  auditLogs                 AuditLog[]
  authoredPosts             PortalContent[]
  createdTimelineEvents     TimelineEvent[]     @relation("TimelineEventAuthor")
  createdLeads              Lead[]              @relation("LeadCreatedBy")
  updatedLeads              Lead[]              @relation("LeadUpdatedBy")
  createdLeadTimelineEvents LeadTimelineEvent[] @relation("LeadTimelineEventAuthor")
  leadImportJobs            LeadImportJob[]
}

model Client {
  id              String          @id @default(uuid())
  userId          String          @unique
  document        String?
  phone           String?
  companyName     String?
  segment         String?
  notes           String?
  status          String?
  internalOwnerId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes         Quote[]
  tickets        Ticket[]
  trackings      Tracking[]
  opportunities  Opportunity[]
  timelineEvents TimelineEvent[]
}

model Lead {
  id                String              @id @default(uuid())
  name              String
  email             String?
  phone             String?
  company           String?
  source            String              @default("manual")
  status            String              @default("new")
  notes             String?
  normalizedEmail   String?
  normalizedPhone   String?
  channel           String?
  sourcePhone       String?
  externalMessageId String?
  externalContactId String?
  metadata          Json?
  rawPayload        Json?
  lastInteractionAt DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  createdBy   User?               @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?               @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  timeline    LeadTimelineEvent[]
  importRows  LeadImportRowResult[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([source, createdAt])
  @@index([status, createdAt])
}

model LeadTimelineEvent {
  id          String                @id @default(uuid())
  leadId      String
  type        LeadTimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User? @relation("LeadTimelineEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([type, createdAt])
}

model LeadImportJob {
  id           String              @id @default(uuid())
  fileName     String
  sourceFileType String
  totalRows    Int                 @default(0)
  successCount Int                 @default(0)
  ignoredCount Int                 @default(0)
  failureCount Int                 @default(0)
  status       LeadImportJobStatus @default(PROCESSING)
  summary      Json?
  createdById  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completedAt  DateTime?

  createdBy User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rowResults LeadImportRowResult[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model LeadImportRowResult {
  id          String              @id @default(uuid())
  jobId       String
  rowNumber   Int
  status      LeadImportRowStatus
  reason      String?
  rawData     Json?
  leadId      String?
  createdAt   DateTime            @default(now())

  job  LeadImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lead Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([leadId])
}

model Opportunity {
  id                String            @id @default(uuid())
  clientId          String
  title             String
  value             Decimal?
  stage             OpportunityStage  @default(NOVO)
  status            OpportunityStatus @default(OPEN)
  expectedCloseDate DateTime?
  lostReason        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, stage])
  @@index([status, createdAt])
}

model TimelineEvent {
  id          String            @id @default(uuid())
  clientId    String
  type        TimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TimelineEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([type, createdAt])
}

model Quote {
  id               String      @id @default(uuid())
  clientId         String
  origin           String
  destination      String
  serviceType      String
  requestType      String?
  pickupAddress    String?
  deliveryAddress  String?
  cargoDescription String?
  contactName      String?
  contactPhone     String?
  weight           Float?
  volume           Float?
  quantity         Int?
  merchandiseValue Decimal?
  desiredDeadline  DateTime?
  notes            String?
  price            Decimal?
  commercialNotes  String?
  status           QuoteStatus @default(RECEIVED)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history QuoteHistory[]
}

model QuoteHistory {
  id        String      @id @default(uuid())
  quoteId   String
  status    QuoteStatus
  notes     String?
  createdAt DateTime    @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String       @id @default(uuid())
  clientId    String
  subject     String
  description String
  status      TicketStatus @default(NOVO)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Tracking {
  id            String         @id @default(uuid())
  clientId      String
  code          String         @unique
  origin        String?
  destination   String?
  carrier       String?
  status        ShipmentStatus @default(RECEIVED)
  description   String?
  estimatedDate DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  client  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history TrackingHistory[]
}

model TrackingHistory {
  id          String         @id @default(uuid())
  trackingId  String
  status      ShipmentStatus
  location    String?
  description String?
  createdAt   DateTime       @default(now())

  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
}

model PortalContent {
  id            String      @id @default(uuid())
  title         String
  summary       String
  body          String
  type          ContentType
  campaignName  String?
  ctaLabel      String?
  ctaUrl        String?
  highlight     Boolean     @default(false)
  coverImageUrl String?
  videoUrl      String?
  isPublished   Boolean     @default(false)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([type, isPublished, publishedAt])
  @@index([authorId, createdAt])
}

model AuditLog {
  id         String           @id @default(uuid())
  category   AuditLogCategory
  action     AuditLogAction
  level      AuditLogLevel    @default(INFO)
  message    String
  details    Json?
  ipAddress  String?
  userAgent  String?
  route      String?
  method     String?
  targetType String?
  targetId   String?
  success    Boolean          @default(true)
  userId     String?
  createdAt  DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([success, createdAt])
}
