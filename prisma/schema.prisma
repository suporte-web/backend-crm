generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  GESTAO
  COMERCIAL
  MARKETING
  CLIENTE
}

enum QuoteStatus {
  RECEIVED
  IN_ANALYSIS
  ANSWERED
  APPROVED
  REJECTED
}

enum TicketStatus {
  NOVO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  FECHADO
}

enum ShipmentStatus {
  RECEIVED
  PREPARING
  COLLECTED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  ISSUE
}

enum MessageSenderType {
  CLIENTE
  INTERNO
  AI
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(CLIENTE)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clientProfile Client?
}

model Client {
  id              String   @id @default(uuid())
  userId          String   @unique
  document        String?
  phone           String?
  companyName     String?
  segment         String?
  notes           String?
  status          String?
  internalOwnerId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes    Quote[]
  tickets   Ticket[]
  trackings Tracking[]
}

model Quote {
  id              String      @id @default(uuid())
  clientId        String
  origin          String
  destination     String
  serviceType     String
  weight          Float?
  volume          Float?
  quantity        Int?
  desiredDeadline DateTime?
  notes           String?
  price           Decimal?
  commercialNotes String?
  status          QuoteStatus @default(RECEIVED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history QuoteHistory[]
}

model QuoteHistory {
  id        String      @id @default(uuid())
  quoteId   String
  status    QuoteStatus
  notes     String?
  createdAt DateTime    @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String       @id @default(uuid())
  clientId    String
  subject     String
  description String
  status      TicketStatus @default(NOVO)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Tracking {
  id            String         @id @default(uuid())
  clientId      String
  code          String         @unique
  origin        String?
  destination   String?
  carrier       String?
  status        ShipmentStatus @default(RECEIVED)
  description   String?
  estimatedDate DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  client  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history TrackingHistory[]
}

model TrackingHistory {
  id          String         @id @default(uuid())
  trackingId  String
  status      ShipmentStatus
  location    String?
  description String?
  createdAt   DateTime       @default(now())

  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
}
