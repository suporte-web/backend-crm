generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  GESTAO
  COMERCIAL
  MARKETING
  CLIENTE
}

enum QuoteStatus {
  RECEIVED
  IN_ANALYSIS
  ANSWERED
  APPROVED
  REJECTED
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  CLOSED
  NOVO
  ABERTO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_COMERCIAL
  AGUARDANDO_GESTAO
  RESPONDIDO
  APROVADO_CLIENTE
  APROVADO_GESTAO
  AJUSTE_SOLICITADO
  REPROVADO
  FECHADO
  CANCELADO
}

enum TicketType {
  COTACAO
  LEAD
  PRE_NEGOCIACAO
  APROVACAO_GESTAO
  AJUSTE_CLIENTE
  AJUSTE_GESTAO
  SUPORTE
  DOCUMENTACAO
  OPERACIONAL
}

enum TicketHistoryEventType {
  CREATED
  STATUS_CHANGED
  MESSAGE_SENT
  INTERNAL_NOTE
  NOTIFICATION_SENT
  EMAIL_SENT
  PRE_PROPOSAL_SENT
  APPROVAL_SENT
  APPROVED
  REJECTED
  ADJUSTMENT_REQUESTED
  CLOSED
}

enum StatusProposta {
  RASCUNHO
  ENVIADA_AO_CLIENTE
  APROVADA_PELO_CLIENTE
  RECUSADA_PELO_CLIENTE
  AJUSTE_SOLICITADO_PELO_CLIENTE
  ENVIADA_PARA_GESTAO
  APROVADA_PELA_GESTAO
  RECUSADA_PELA_GESTAO
  AJUSTE_SOLICITADO_PELA_GESTAO
  CANCELADA
  EXPIRADA
}

enum StatusLogEmail {
  PENDENTE
  ENVIADO
  FALHOU
  IGNORADO
}

enum ShipmentStatus {
  RECEIVED
  PREPARING
  COLLECTED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  ISSUE
}

enum TimelineEventType {
  LEAD_CREATED
  LEAD_UPDATED
  OPPORTUNITY_CREATED
  STAGE_CHANGED
  NOTE_ADDED
  OPPORTUNITY_WON
  OPPORTUNITY_LOST
}

enum OpportunityStage {
  NOVO
  QUALIFICADO
  PROPOSTA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum LeadTimelineEventType {
  CREATED_MANUAL
  IMPORTED_CSV
  UPDATED
  WHATSAPP_CREATED
  WHATSAPP_INTERACTION
  NOTE_ADDED
}

enum LeadImportJobStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum LeadImportRowStatus {
  IMPORTED
  SKIPPED
  FAILED
}

enum MessageSenderType {
  CLIENT
  AGENT
  CLIENTE
  INTERNO
  AI
}

enum ContentType {
  NOTICIA
  INFORMACAO
  VLOG
}

enum AuditLogCategory {
  ACCESS
  AUTH
  USER
  CLIENT
  QUOTE
  TICKET
  TRACKING
  SYSTEM
}

enum AuditLogLevel {
  INFO
  WARNING
  ERROR
}

enum AuditLogAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  SESSION_VALIDATED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_STATUS_CHANGED
  CLIENT_CREATED
  CLIENT_UPDATED
  QUOTE_CREATED
  QUOTE_STATUS_CHANGED
  QUOTE_RESPONDED
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  TICKET_RESPONDED
  TRACKING_QUERIED
  TRACKING_UPDATED
  OPPORTUNITY_CREATED
  OPPORTUNITY_STAGE_CHANGED
  SUPPLIER_INVITED
  CUSTOM
}

enum SupplierInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CLIENTE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientProfile             Client?
  auditLogs                 AuditLog[]
  authoredPosts             PortalContent[]
  supplierInvites           SupplierInvite[]    @relation("SupplierInviteAuthor")
  createdTimelineEvents     TimelineEvent[]     @relation("TimelineEventAuthor")
  createdLeads              Lead[]              @relation("LeadCreatedBy")
  updatedLeads              Lead[]              @relation("LeadUpdatedBy")
  createdLeadTimelineEvents LeadTimelineEvent[] @relation("LeadTimelineEventAuthor")
  leadImportJobs            LeadImportJob[]
  ticketMessages            TicketMessage[]     @relation("TicketMessageAuthor")
  assignedTickets           Ticket[]            @relation("TicketAssignedTo")
  requestedTickets          Ticket[]            @relation("TicketRequester")
  ticketHistoryEvents       TicketHistory[]     @relation("TicketHistoryActor")
  notifications             Notification[]
  propostasCriadas          Proposta[]          @relation("PropostaCriadaPor")
  propostasEnviadas         Proposta[]          @relation("PropostaEnviadaPor")
  logsEmail                 LogEmail[]
}

model Client {
  id              String   @id @default(uuid())
  userId          String   @unique
  document        String?
  phone           String?
  companyName     String?
  segment         String?
  notes           String?
  status          String?
  internalOwnerId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes         Quote[]
  tickets        Ticket[]
  trackings      Tracking[]
  opportunities  Opportunity[]
  timelineEvents TimelineEvent[]
  propostas      Proposta[]
}

model Lead {
  id                String    @id @default(uuid())
  name              String
  email             String?
  phone             String?
  company           String?
  source            String    @default("manual")
  status            String    @default("new")
  notes             String?
  normalizedEmail   String?
  normalizedPhone   String?
  channel           String?
  sourcePhone       String?
  externalMessageId String?
  externalContactId String?
  metadata          Json?
  rawPayload        Json?
  lastInteractionAt DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBy  User?                 @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?                 @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  timeline   LeadTimelineEvent[]
  importRows LeadImportRowResult[]
  tickets    Ticket[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([source, createdAt])
  @@index([status, createdAt])
}

model LeadTimelineEvent {
  id          String                @id @default(uuid())
  leadId      String
  type        LeadTimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User? @relation("LeadTimelineEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([type, createdAt])
}

model LeadImportJob {
  id             String              @id @default(uuid())
  fileName       String
  sourceFileType String
  totalRows      Int                 @default(0)
  successCount   Int                 @default(0)
  ignoredCount   Int                 @default(0)
  failureCount   Int                 @default(0)
  status         LeadImportJobStatus @default(PROCESSING)
  summary        Json?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  completedAt    DateTime?

  createdBy  User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rowResults LeadImportRowResult[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model LeadImportRowResult {
  id        String              @id @default(uuid())
  jobId     String
  rowNumber Int
  status    LeadImportRowStatus
  reason    String?
  rawData   Json?
  leadId    String?
  createdAt DateTime            @default(now())

  job  LeadImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lead Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([leadId])
}

model Opportunity {
  id                String            @id @default(uuid())
  clientId          String
  quoteId           String?
  title             String
  value             Decimal?
  stage             OpportunityStage  @default(NOVO)
  status            OpportunityStatus @default(OPEN)
  preContract       Boolean           @default(false)
  preContractNotes  String?
  expectedCloseDate DateTime?
  lostReason        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quote     Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  tickets   Ticket[]
  propostas Proposta[]

  @@index([clientId, stage])
  @@index([quoteId])
  @@index([status, createdAt])
}

model TimelineEvent {
  id          String            @id @default(uuid())
  clientId    String
  type        TimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TimelineEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([type, createdAt])
}

model Quote {
  id               String      @id @default(uuid())
  clientId         String
  origin           String
  destination      String
  serviceType      String
  requestType      String?
  pickupAddress    String?
  deliveryAddress  String?
  cargoDescription String?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  weight           Float?
  volume           Float?
  quantity         Int?
  merchandiseValue Decimal?
  desiredDeadline  DateTime?
  notes            String?
  price            Decimal?
  commercialNotes  String?
  status           QuoteStatus @default(RECEIVED)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history       QuoteHistory[]
  tickets       Ticket[]
  opportunities Opportunity[]
  propostas     Proposta[]
}

model QuoteHistory {
  id        String      @id @default(uuid())
  quoteId   String
  status    QuoteStatus
  notes     String?
  createdAt DateTime    @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id                 String       @id @default(uuid())
  clientId           String?
  quoteId            String?
  leadId             String?
  opportunityId      String?
  assignedToId       String?
  requesterId        String?
  type               TicketType   @default(SUPORTE)
  subject            String
  description        String
  status             TicketStatus @default(ABERTO)
  requiresActionRole UserRole?
  lastInteractionAt  DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  client        Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quote         Quote?          @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lead          Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunity   Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignedTo    User?           @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  requester     User?           @relation("TicketRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  messages      TicketMessage[]
  history       TicketHistory[]
  notifications Notification[]
  propostas     Proposta[]
  logsEmail     LogEmail[]

  @@index([clientId])
  @@index([quoteId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([assignedToId, status])
  @@index([type, status])
  @@index([requiresActionRole, status])
  @@index([status, createdAt])
  @@index([lastInteractionAt])
}

model TicketMessage {
  id          String            @id @default(uuid())
  ticketId    String
  senderType  MessageSenderType @default(INTERNO)
  message     String
  isInternal  Boolean           @default(false)
  attachments Json?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TicketMessageAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([createdById, createdAt])
}

model TicketHistory {
  id           String                 @id @default(uuid())
  ticketId     String
  eventType    TicketHistoryEventType
  title        String
  description  String
  metadata     Json?
  internalOnly Boolean                @default(false)
  createdById  String?
  createdAt    DateTime               @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TicketHistoryActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdById, createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  ticketId  String?
  title     String
  message   String
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket    Ticket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  logsEmail LogEmail[]

  @@index([userId, readAt, createdAt])
  @@index([ticketId, createdAt])
}

model Proposta {
  id            String  @id @default(uuid())
  ticketId      String
  quoteId       String?
  opportunityId String?
  clientId      String?
  criadaPorId   String?
  enviadaPorId  String?

  status StatusProposta @default(RASCUNHO)

  titulo                        String
  descricao                     String?
  descricaoServico              String?
  origem                        String?
  destino                       String?
  valor                         Decimal?
  condicoesPagamento            String?
  condicoesComerciais           String?
  observacoes                   String?
  validadeDias                  Int?
  validaAte                     DateTime?
  versao                        Int       @default(1)
  enviadaEm                     DateTime?
  aprovadaPeloClienteEm         DateTime?
  recusadaPeloClienteEm         DateTime?
  ajusteSolicitadoPeloClienteEm DateTime?
  enviadaParaGestaoEm           DateTime?
  aprovadaPelaGestaoEm          DateTime?
  recusadaPelaGestaoEm          DateTime?
  ajusteSolicitadoPelaGestaoEm  DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  quote       Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  criadaPor   User?        @relation("PropostaCriadaPor", fields: [criadaPorId], references: [id], onDelete: SetNull)
  enviadaPor  User?        @relation("PropostaEnviadaPor", fields: [enviadaPorId], references: [id], onDelete: SetNull)
  logsEmail   LogEmail[]

  @@index([ticketId])
  @@index([quoteId])
  @@index([opportunityId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([ticketId, versao])
}

model LogEmail {
  id             String  @id @default(uuid())
  ticketId       String?
  propostaId     String?
  notificationId String?
  userId         String?

  emailDestino String
  assunto      String
  resumo       String?
  template     String?

  status StatusLogEmail @default(PENDENTE)

  provedor           String?
  idMensagemProvedor String?
  mensagemErro       String?
  enviadoEm          DateTime?
  createdAt          DateTime  @default(now())

  ticket       Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  proposta     Proposta?     @relation(fields: [propostaId], references: [id], onDelete: SetNull)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([propostaId])
  @@index([notificationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Tracking {
  id            String         @id @default(uuid())
  clientId      String
  code          String         @unique
  origin        String?
  destination   String?
  carrier       String?
  status        ShipmentStatus @default(RECEIVED)
  description   String?
  estimatedDate DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  client  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history TrackingHistory[]
}

model TrackingHistory {
  id          String         @id @default(uuid())
  trackingId  String
  status      ShipmentStatus
  location    String?
  description String?
  createdAt   DateTime       @default(now())

  tracking Tracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
}

model PortalContent {
  id            String      @id @default(uuid())
  title         String
  summary       String
  body          String
  type          ContentType
  campaignName  String?
  ctaLabel      String?
  ctaUrl        String?
  highlight     Boolean     @default(false)
  coverImageUrl String?
  videoUrl      String?
  isPublished   Boolean     @default(false)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([type, isPublished, publishedAt])
  @@index([authorId, createdAt])
}

model AuditLog {
  id         String           @id @default(uuid())
  category   AuditLogCategory
  action     AuditLogAction
  level      AuditLogLevel    @default(INFO)
  message    String
  details    Json?
  ipAddress  String?
  userAgent  String?
  route      String?
  method     String?
  targetType String?
  targetId   String?
  success    Boolean          @default(true)
  userId     String?
  createdAt  DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([success, createdAt])
}

model SupplierInvite {
  id          String               @id @default(uuid())
  companyName String
  contactName String?
  email       String
  phone       String?
  token       String               @unique
  status      SupplierInviteStatus @default(PENDING)
  notes       String?
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  invitedBy User? @relation("SupplierInviteAuthor", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([status, createdAt])
}
