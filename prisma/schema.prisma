generator client {
  provider = "prisma-client-js"
  
}



datasource db {
  provider = "postgresql"
}

model User {
  id                        String              @id @default(uuid())
  name                      String
  email                     String              @unique
  passwordHash              String
  mustChangePassword        Boolean             @default(true)
  role                      UserRole            @default(CLIENTE)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  isActive                  Boolean             @default(true)
  auditLogs                 AuditLog[]
  clientProfile             Client?
  createdLeads              Lead[]              @relation("LeadCreatedBy")
  updatedLeads              Lead[]              @relation("LeadUpdatedBy")
  leadImportJobs            LeadImportJob[]
  createdLeadTimelineEvents LeadTimelineEvent[] @relation("LeadTimelineEventAuthor")
  logsEmail                 LogEmail[]
  notifications             Notification[]
  authoredPosts             PortalContent[]
  propostasCriadas          Proposta[]          @relation("PropostaCriadaPor")
  propostasEnviadas         Proposta[]          @relation("PropostaEnviadaPor")
  requestedClientDeletionRequests ClientDeletionRequest[] @relation("ClientDeletionRequestedBy")
  approvedClientDeletionRequests  ClientDeletionRequest[] @relation("ClientDeletionApprovedBy")
  supplierInvites           SupplierInvite[]    @relation("SupplierInviteAuthor")
  assignedTickets           Ticket[]            @relation("TicketAssignedTo")
  requestedTickets          Ticket[]            @relation("TicketRequester")
  ticketHistoryEvents       TicketHistory[]     @relation("TicketHistoryActor")
  ticketMessages            TicketMessage[]     @relation("TicketMessageAuthor")
  createdTimelineEvents     TimelineEvent[]     @relation("TimelineEventAuthor")
  chatParticipants          ChatParticipant[]
  chatMessages              ChatMessage[]       @relation("ChatMessageAuthor")
  privateChatMessages       ChatMessageRecipient[]
}

model Client {
  id              String          @id @default(uuid())
  userId          String          @unique
  document        String?
  phone           String?
  companyName     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  internalOwnerId String?
  notes           String?
  segment         String?
  status          String?
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunities   Opportunity[]
  propostas       Proposta[]
  quotes          Quote[]
  tickets         Ticket[]
  timelineEvents  TimelineEvent[]
  trackings       Tracking[]
  deletionRequests ClientDeletionRequest[]
  chats           Chat[]
}

model Lead {
  id                String                @id @default(uuid())
  name              String
  email             String?
  phone             String?
  company           String?
  source            String                @default("manual")
  status            String                @default("new")
  notes             String?
  normalizedEmail   String?
  normalizedPhone   String?
  channel           String?
  sourcePhone       String?
  externalMessageId String?
  externalContactId String?
  metadata          Json?
  rawPayload        Json?
  lastInteractionAt DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  createdBy         User?                 @relation("LeadCreatedBy", fields: [createdById], references: [id])
  updatedBy         User?                 @relation("LeadUpdatedBy", fields: [updatedById], references: [id])
  importRows        LeadImportRowResult[]
  timeline          LeadTimelineEvent[]
  tickets           Ticket[]
  chats             Chat[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([source, createdAt])
  @@index([status, createdAt])
}

model Prospect {
  id                 String                     @id @default(uuid())
  nomeRazaoSocial    String
  nomeContato        String?
  email              String?
  telefone           String?
  document           String?
  cidade             String?
  estado             String?
  origem             EntradaOrigem             @default(SITE)
  statusCadastral    ProspectStatusCadastral   @default(PROSPECT)
  portalAccessStatus ProspectPortalAccessStatus @default(SEM_ACESSO)
  createdFromTicketId String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  createdFromTicket  Ticket?                    @relation("ProspectCreatedFromTicket", fields: [createdFromTicketId], references: [id])
  tickets            Ticket[]                   @relation("TicketProspect")
  quotes             Quote[]

  @@index([email])
  @@index([telefone])
  @@index([document])
  @@index([statusCadastral, createdAt])
  @@index([origem, createdAt])
}

model LeadTimelineEvent {
  id          String                @id @default(uuid())
  leadId      String
  type        LeadTimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   User?                 @relation("LeadTimelineEventAuthor", fields: [createdById], references: [id])
  lead        Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([type, createdAt])
}

model LeadImportJob {
  id             String                @id @default(uuid())
  fileName       String
  sourceFileType String
  totalRows      Int                   @default(0)
  successCount   Int                   @default(0)
  ignoredCount   Int                   @default(0)
  failureCount   Int                   @default(0)
  status         LeadImportJobStatus   @default(PROCESSING)
  summary        Json?
  createdById    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  completedAt    DateTime?
  createdBy      User?                 @relation(fields: [createdById], references: [id])
  rowResults     LeadImportRowResult[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model LeadImportRowResult {
  id        String              @id @default(uuid())
  jobId     String
  rowNumber Int
  status    LeadImportRowStatus
  reason    String?
  rawData   Json?
  leadId    String?
  createdAt DateTime            @default(now())
  job       LeadImportJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lead      Lead?               @relation(fields: [leadId], references: [id])

  @@index([jobId, rowNumber])
  @@index([leadId])
}

model Opportunity {
  id                String            @id @default(uuid())
  clientId          String
  title             String
  value             Decimal?
  stage             OpportunityStage  @default(NOVO)
  status            OpportunityStatus @default(OPEN)
  expectedCloseDate DateTime?
  lostReason        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  quoteId           String?
  preContract       Boolean           @default(false)
  preContractNotes  String?
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quote             Quote?            @relation(fields: [quoteId], references: [id])
  propostas         Proposta[]
  tickets           Ticket[]

  @@index([clientId, stage])
  @@index([quoteId])
  @@index([status, createdAt])
}

model TimelineEvent {
  id          String            @id @default(uuid())
  clientId    String
  type        TimelineEventType
  title       String
  description String
  metadata    Json?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?             @relation("TimelineEventAuthor", fields: [createdById], references: [id])

  @@index([clientId, createdAt])
  @@index([type, createdAt])
}

model Quote {
  id               String         @id @default(uuid())
  code             String         @unique
  clientId         String?
  prospectId       String?
  origin           String
  destination      String
  serviceType      String
  weight           Float?
  volume           Float?
  quantity         Int?
  desiredDeadline  String?
  notes            String?
  price            Decimal?
  commercialNotes  String?
  status           QuoteStatus    @default(RECEIVED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cargoDescription String?
  contactName      String?
  contactPhone     String?
  deliveryAddress  String?
  merchandiseValue Decimal?
  pickupAddress    String?
  requestType      String?
  contactEmail     String?
  opportunities    Opportunity[]
  propostas        Proposta[]
  client           Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prospect         Prospect?      @relation(fields: [prospectId], references: [id])
  history          QuoteHistory[]
  tickets          Ticket[]
  chats            Chat[]

  @@index([prospectId])
}

model QuoteHistory {
  id        String      @id @default(uuid())
  quoteId   String
  status    QuoteStatus
  notes     String?
  createdAt DateTime    @default(now())
  quote     Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id                 String          @id @default(uuid())
  protocolo          String?         @unique
  clientId           String?
  prospectId         String?
  subject            String
  description        String
  status             TicketStatus    @default(ABERTO)
  origem             EntradaOrigem?
  prioridade         TicketPriority   @default(NORMAL)
  nomeSolicitante    String?
  emailSolicitante   String?
  telefoneSolicitante String?
  mensagem           String?
  formPayload        Json?
  closedAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  quoteId            String?
  leadId             String?
  opportunityId      String?
  assignedToId       String?
  requesterId        String?
  type               TicketType      @default(SUPORTE)
  requiresActionRole UserRole?
  internalOnly       Boolean         @default(false)
  lastInteractionAt  DateTime        @default(now())
  logsEmail          LogEmail[]
  notifications      Notification[]
  propostas          Proposta[]
  assignedTo         User?           @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  client             Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prospect           Prospect?       @relation("TicketProspect", fields: [prospectId], references: [id])
  lead               Lead?           @relation(fields: [leadId], references: [id])
  opportunity        Opportunity?    @relation(fields: [opportunityId], references: [id])
  quote              Quote?          @relation(fields: [quoteId], references: [id])
  requester          User?           @relation("TicketRequester", fields: [requesterId], references: [id])
  createdProspects   Prospect[]      @relation("ProspectCreatedFromTicket")
  history            TicketHistory[]
  messages           TicketMessage[]
  chats              Chat[]

  @@index([clientId])
  @@index([prospectId])
  @@index([quoteId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([assignedToId, status])
  @@index([type, status])
  @@index([requiresActionRole, status])
  @@index([internalOnly, status])
  @@index([status, createdAt])
  @@index([lastInteractionAt])
  @@index([origem, createdAt])
  @@index([protocolo])
}

model TicketMessage {
  id          String            @id @default(uuid())
  ticketId    String
  senderType  MessageSenderType @default(INTERNO)
  message     String
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isInternal  Boolean           @default(false)
  attachments Json?
  createdBy   User?             @relation("TicketMessageAuthor", fields: [createdById], references: [id])
  ticket      Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([createdById, createdAt])
}

model TicketHistory {
  id           String                 @id @default(uuid())
  ticketId     String
  eventType    TicketHistoryEventType
  title        String
  description  String
  metadata     Json?
  internalOnly Boolean                @default(false)
  createdById  String?
  createdAt    DateTime               @default(now())
  createdBy    User?                  @relation("TicketHistoryActor", fields: [createdById], references: [id])
  ticket       Ticket                 @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdById, createdAt])
}

model Notification {
  id        String     @id @default(uuid())
  userId    String
  ticketId  String?
  title     String
  message   String
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime   @default(now())
  logsEmail LogEmail[]
  ticket    Ticket?    @relation(fields: [ticketId], references: [id])
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([ticketId, createdAt])
}

model Proposta {
  id                            String         @id @default(uuid())
  code                          String         @unique
  ticketId                      String
  quoteId                       String?
  opportunityId                 String?
  clientId                      String?
  criadaPorId                   String?
  enviadaPorId                  String?
  status                        StatusProposta @default(RASCUNHO)
  titulo                        String
  descricao                     String?
  descricaoServico              String?
  origem                        String?
  destino                       String?
  valor                         Decimal?
  condicoesPagamento            String?
  condicoesComerciais           String?
  observacoes                   String?
  arquivoNome                   String?
  arquivoUrl                    String?
  arquivoMimeType               String?
  arquivoTamanho                Int?
  validadeDias                  String?
  validaAte                     DateTime?
  versao                        Int            @default(1)
  enviadaEm                     DateTime?
  aprovadaPeloClienteEm         DateTime?
  recusadaPeloClienteEm         DateTime?
  motivoRecusaCliente           String?
  ajusteSolicitadoPeloClienteEm DateTime?
  enviadaParaGestaoEm           DateTime?
  aprovadaPelaGestaoEm          DateTime?
  recusadaPelaGestaoEm          DateTime?
  ajusteSolicitadoPelaGestaoEm  DateTime?
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt
  logsEmail                     LogEmail[]
  client                        Client?        @relation(fields: [clientId], references: [id])
  criadaPor                     User?          @relation("PropostaCriadaPor", fields: [criadaPorId], references: [id])
  enviadaPor                    User?          @relation("PropostaEnviadaPor", fields: [enviadaPorId], references: [id])
  opportunity                   Opportunity?   @relation(fields: [opportunityId], references: [id])
  quote                         Quote?         @relation(fields: [quoteId], references: [id])
  ticket                        Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  chats                         Chat[]

  @@index([ticketId])
  @@index([quoteId])
  @@index([opportunityId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([ticketId, versao])
}

model LogEmail {
  id                 String         @id @default(uuid())
  ticketId           String?
  propostaId         String?
  notificationId     String?
  userId             String?
  emailDestino       String
  assunto            String
  resumo             String?
  template           String?
  status             StatusLogEmail @default(PENDENTE)
  provedor           String?
  idMensagemProvedor String?
  mensagemErro       String?
  enviadoEm          DateTime?
  createdAt          DateTime       @default(now())
  notification       Notification?  @relation(fields: [notificationId], references: [id])
  proposta           Proposta?      @relation(fields: [propostaId], references: [id])
  ticket             Ticket?        @relation(fields: [ticketId], references: [id])
  user               User?          @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([propostaId])
  @@index([notificationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Chat {
  id           String            @id @default(uuid())
  entityType   ChatEntityType
  entityId     String
  title        String?
  leadId       String?
  clientId     String?
  quoteId      String?
  propostaId   String?
  ticketId     String?
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  messages     ChatMessage[]
  client       Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proposta     Proposta?         @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  quote        Quote?            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  ticket       Ticket?           @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([clientId])
  @@index([leadId])
  @@index([quoteId])
  @@index([propostaId])
  @@index([ticketId])
  @@index([entityType, createdAt])
}

model ChatParticipant {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(true)
  lastReadAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, canRead])
  @@index([chatId, canWrite])
}

model ChatMessage {
  id         String                 @id @default(uuid())
  chatId     String
  authorId   String
  content    String
  visibility ChatMessageVisibility @default(PUBLICA_CLIENTE)
  editedAt   DateTime?
  deletedAt  DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  author     User                   @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  chat       Chat                   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  recipients ChatMessageRecipient[]

  @@index([chatId, createdAt])
  @@index([authorId, createdAt])
  @@index([visibility])
  @@index([deletedAt])
}

model ChatMessageRecipient {
  id        String      @id @default(uuid())
  messageId String
  userId    String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model Tracking {
  id            String            @id @default(uuid())
  clientId      String
  code          String            @unique
  origin        String?
  destination   String?
  carrier       String?
  status        ShipmentStatus    @default(RECEIVED)
  description   String?
  estimatedDate DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  history       TrackingHistory[]
}

model TrackingHistory {
  id          String         @id @default(uuid())
  trackingId  String
  status      ShipmentStatus
  location    String?
  description String?
  createdAt   DateTime       @default(now())
  tracking    Tracking       @relation(fields: [trackingId], references: [id], onDelete: Cascade)
}

model PortalContent {
  id            String      @id @default(uuid())
  title         String
  summary       String
  body          String
  type          ContentType
  coverImageUrl String?
  videoUrl      String?
  isPublished   Boolean     @default(false)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  campaignName  String?
  ctaLabel      String?
  ctaUrl        String?
  highlight     Boolean     @default(false)
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([type, isPublished, publishedAt])
  @@index([authorId, createdAt])
}

model AuditLog {
  id         String           @id @default(uuid())
  category   AuditLogCategory
  action     AuditLogAction
  level      AuditLogLevel    @default(INFO)
  message    String
  details    Json?
  ipAddress  String?
  userAgent  String?
  route      String?
  method     String?
  targetType String?
  targetId   String?
  success    Boolean          @default(true)
  userId     String?
  createdAt  DateTime         @default(now())
  user       User?            @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([success, createdAt])
}

model SupplierInvite {
  id          String               @id @default(uuid())
  companyName String
  contactName String?
  email       String
  phone       String?
  token       String               @unique
  status      SupplierInviteStatus @default(PENDING)
  notes       String?
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  invitedBy   User?                @relation("SupplierInviteAuthor", fields: [invitedById], references: [id])

  @@index([email, createdAt])
  @@index([status, createdAt])
}

model ClientDeletionRequest {
  id                  String                      @id @default(uuid())
  clientId            String?
  requestedById       String
  approvedById        String?
  status              ClientDeletionRequestStatus @default(PENDENTE)
  reason              String?
  managementResponse  String?
  clientNameSnapshot  String?
  clientEmailSnapshot String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  decidedAt           DateTime?
  client              Client?                     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  requestedBy         User                        @relation("ClientDeletionRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy          User?                       @relation("ClientDeletionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([status, createdAt])
  @@index([requestedById, createdAt])
  @@index([approvedById, createdAt])
}

enum UserRole {
  ADMIN
  GESTAO
  COMERCIAL
  MARKETING
  CLIENTE
}

enum QuoteStatus {
  RECEIVED
  IN_ANALYSIS
  ANSWERED
  APPROVED
  REJECTED
}

enum TicketStatus {
  NOVO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  FECHADO
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  CLOSED
  ABERTO
  AGUARDANDO_COMERCIAL
  AGUARDANDO_GESTAO
  RESPONDIDO
  APROVADO_CLIENTE
  APROVADO_GESTAO
  AJUSTE_SOLICITADO
  REPROVADO
  CANCELADO
  CONVERTIDO_EM_PROSPECT
  COTACAO_CRIADA
  FINALIZADO
  PERDIDO
  TRANSFERIDO
}

enum TicketType {
  COTACAO
  LEAD
  PRE_NEGOCIACAO
  APROVACAO_GESTAO
  AJUSTE_CLIENTE
  AJUSTE_GESTAO
  SUPORTE
  DOCUMENTACAO
  OPERACIONAL
  FORNECEDOR
  AGREGADO
  FINANCEIRO
  FISCAL
  JURIDICO
  MARKETING
  FROTA
}

enum EntradaOrigem {
  SITE
  PORTAL
  MANUAL
}

enum TicketPriority {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum ProspectStatusCadastral {
  PROSPECT
  AGUARDANDO_CADASTRO
  EM_VALIDACAO
  ATIVO
  REPROVADO
  INATIVO
}

enum ProspectPortalAccessStatus {
  SEM_ACESSO
  CONVITE_ENVIADO
  ATIVO
  BLOQUEADO
}

enum TicketHistoryEventType {
  CREATED
  STATUS_CHANGED
  MESSAGE_SENT
  INTERNAL_NOTE
  NOTIFICATION_SENT
  EMAIL_SENT
  PRE_PROPOSAL_SENT
  APPROVAL_SENT
  APPROVED
  REJECTED
  ADJUSTMENT_REQUESTED
  CLOSED
}

enum StatusProposta {
  RASCUNHO
  ENVIADA_AO_CLIENTE
  APROVADA_PELO_CLIENTE
  RECUSADA_PELO_CLIENTE
  AJUSTE_SOLICITADO_PELO_CLIENTE
  ENVIADA_PARA_GESTAO
  APROVADA_PELA_GESTAO
  RECUSADA_PELA_GESTAO
  AJUSTE_SOLICITADO_PELA_GESTAO
  CANCELADA
  EXPIRADA
}

enum StatusLogEmail {
  PENDENTE
  ENVIADO
  FALHOU
  IGNORADO
}

enum ShipmentStatus {
  RECEIVED
  PREPARING
  COLLECTED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  ISSUE
}

enum TimelineEventType {
  LEAD_CREATED
  LEAD_UPDATED
  OPPORTUNITY_CREATED
  STAGE_CHANGED
  NOTE_ADDED
  OPPORTUNITY_WON
  OPPORTUNITY_LOST
}

enum OpportunityStage {
  NOVO
  QUALIFICADO
  PROPOSTA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum LeadTimelineEventType {
  CREATED_MANUAL
  IMPORTED_CSV
  UPDATED
  WHATSAPP_CREATED
  WHATSAPP_INTERACTION
  NOTE_ADDED
}

enum LeadImportJobStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum LeadImportRowStatus {
  IMPORTED
  SKIPPED
  FAILED
}

enum MessageSenderType {
  CLIENTE
  INTERNO
  AI
  CLIENT
  AGENT
}

enum ChatEntityType {
