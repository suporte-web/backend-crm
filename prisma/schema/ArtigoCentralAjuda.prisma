model HelpCenterArticle {
  id          String   @id @default(uuid())
  title       String
  questions   String[]
  answer      String
  category    String
  tags        String[]
  active      Boolean  @default(true)
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("HelpCenterArticleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("HelpCenterArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([active, category])
  @@index([createdAt])
}
